#!/bin/sh

umask 077

# create backup dir if not exist.
BACKUP_DIR="{{ dir_backup_output_dir }}"
[ ! -d "$BACKUP_DIR" ] && mkdir "$BACKUP_DIR" || true

{% for target in dir_backup_targets %}
# {{ target.name }}
[ ! -d "$BACKUP_DIR/{{ target.name.rstrip('/') }}" ] && mkdir "$BACKUP_DIR/{{ target.name.rstrip('/') }}" || true
bash {{ dir_backup_core_script_install_dir }}/{{ dir_backup_core_script_name }} {{ target.src.rstrip('/') }}/ "$BACKUP_DIR/{{ target.name.rstrip('/') }}/"

{% endfor %}
exit 0
